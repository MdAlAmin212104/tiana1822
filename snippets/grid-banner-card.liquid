{%- liquid
  assign banner_heading = collection.metafields.custom.banner_heading.value | default: collection.metafields.custom.banner_heading
  assign banner_button = collection.metafields.custom.banner_button.value | default: collection.metafields.custom.banner_button
  assign banner_image = collection.metafields.custom.banner_image.value | default: collection.metafields.custom.banner_image
  assign banner_link = collection.metafields.custom.banner_link.value | default: collection.metafields.custom.banner_link

  if banner_heading == blank
    assign banner_heading = section.settings.default_banner_heading
  endif

  if banner_button == blank
    assign banner_button = section.settings.default_banner_button
  endif

  if banner_image == blank
    assign banner_image = section.settings.default_banner_image
  endif

  if banner_link == blank
    assign banner_link = section.settings.default_banner_link | default: "#"
  endif
-%}

<li class="grid__item {{ gridProduct }} banner-card-grid-item">
  <a href="{{ banner_link }}" class="banner-card-link">
    <div class="banner-card-container">
      {%- if banner_image != blank -%}
        <div class="banner-card-bg-wrap">
          <img class="banner-card-bg lazyload"
               src="{{ banner_image | image_url: width: 300 }}"
               data-src="{{ banner_image | image_url: width: 800 }}"
               data-sizes="auto"
               alt="{{ banner_heading | strip_html | escape }}"
               loading="lazy">
        </div>
      {%- endif -%}
      <div class="banner-card-overlay"></div>
      <div class="banner-card-content">
        {%- if banner_heading != blank -%}
          <div class="banner-card-title">
            {{ banner_heading }}
          </div>
        {%- endif -%}
        {%- if banner_button != blank -%}
          <span class="btn btn-theme">{{ banner_button }}</span>
        {%- endif -%}
      </div>
    </div>
  </a>
</li>

<style>
.banner-card-grid-item {
  list-style: none;
}
.banner-card-link {
  text-decoration: none;
  display: block;
  height: 100%;
}
.banner-card-container {
  position: relative;
  width: 100%;
  height: 100%;
  min-height: 400px;
  border-radius: var(--card-corner-radius, 8px);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  text-align: center;
  padding: 10px;
  background-color: #f4f4f4;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.banner-card-bg-wrap {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  overflow: hidden;
}
.banner-card-bg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.banner-card-link:hover .banner-card-bg {
  transform: scale(1.05);
}
.banner-card-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to bottom, rgba(0, 0, 0, 0) 40%, rgba(0, 0, 0, 0.45) 100%);
  z-index: 2;
  transition: opacity 0.4s ease;
}
.banner-card-link:hover .banner-card-overlay {
  background: linear-gradient(to bottom, rgba(0, 0, 0, 0) 30%, rgba(0, 0, 0, 0.55) 100%);
}
.banner-card-content {
  position: relative;
  z-index: 3;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15px;
}
.banner-card-title {
  color: #ffffff;
  font-size: 24px;
  font-weight: 500;
  line-height: 1.2;
  margin: 0;
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
  font-family: var(--font-heading-family);
}
/* If the heading is rich text, target nested paragraph tags */
.banner-card-title p {
  color: #ffffff;
  font-size: 24px;
  font-weight: 500;
  line-height: 1.2;
  margin: 0 !important;
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
  font-family: var(--font-heading-family);
}
.banner-card-button {
  background-color: #ffffff;
  color: #000000;
  padding: 10px 24px;
  font-size: 14px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  border-radius: 0;
  border: none;
  box-shadow: 0 4px 6px rgba(0,0,0,0.05);
  transition: all 0.3s ease;
}
.banner-card-link:hover .banner-card-button {
  background-color: #000000;
  color: #ffffff;
}
@media (max-width: 767px) {
  .banner-card-container {
    min-height: 350px;
    padding: 10px;
  }
  .banner-card-title,
  .banner-card-title p {
    font-size: 20px;
  }
  .banner-card-button {
    padding: 8px 20px;
    font-size: 12px;
  }
}
</style>
