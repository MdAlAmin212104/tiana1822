{% comment %} {% doc %}
  @prompt
    Create a featured product slider that includes product picture, product title, and product description, Change the featured products slider to a slider for collections, Make the pictures editable
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collections-slider-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    display: block;
  }

  .ai-collections-slider__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-collections-slider__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
  }

  .ai-collections-slider__container-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-collections-slider__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.slide_gap }}px;
    transition: transform 0.5s ease;
  }

  .ai-collections-slider__slide-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.slides_per_view | minus: 1 }} * {{ block.settings.slide_gap }}px)) / {{ block.settings.slides_per_view }});
    min-width: 0;
  }

  .ai-collections-slider__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .ai-collections-slider__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-collections-slider__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-collections-slider__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-collections-slider__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-collections-slider__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-collections-slider__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px 0;
    font-weight: 600;
  }

  .ai-collections-slider__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.5;
    margin: 0;
  }

  .ai-collections-slider__nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: {{ block.settings.nav_spacing }}px;
  }

  .ai-collections-slider__button-{{ ai_gen_id }} {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: {{ block.settings.nav_button_background }};
    color: {{ block.settings.nav_button_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease;
  }

  .ai-collections-slider__button-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-collections-slider__button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-collections-slider__button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-collections-slider__dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-collections-slider__dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ block.settings.nav_button_background }};
    opacity: 0.3;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.3s ease;
  }

  .ai-collections-slider__dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-collections-slider__slide-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.slides_per_view_mobile | minus: 1 }} * {{ block.settings.slide_gap }}px)) / {{ block.settings.slides_per_view_mobile }});
    }

    .ai-collections-slider__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<collections-slider-{{ ai_gen_id }} class="ai-collections-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <div class="ai-collections-slider__header-{{ ai_gen_id }}">
      <h2 class="ai-collections-slider__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    </div>
  {% endif %}

  <div class="ai-collections-slider__container-{{ ai_gen_id }}">
    <div class="ai-collections-slider__track-{{ ai_gen_id }}" data-track>
      {% for i in (1..6) %}
        {% liquid
          assign collection_key = 'collection_' | append: i
          assign image_key = 'image_' | append: i
          assign title_key = 'title_' | append: i
          assign description_key = 'description_' | append: i
          
          assign collection = block.settings[collection_key]
          assign custom_image = block.settings[image_key]
          assign custom_title = block.settings[title_key]
          assign custom_description = block.settings[description_key]
          
          if collection != blank or custom_image != blank or custom_title != blank or custom_description != blank
            assign show_slide = true
          else
            assign show_slide = false
          endif
        %}

        {% if show_slide %}
          <div class="ai-collections-slider__slide-{{ ai_gen_id }}">
            <div class="ai-collections-slider__card-{{ ai_gen_id }}">
              <div class="ai-collections-slider__image-wrapper-{{ ai_gen_id }}">
                {% if custom_image != blank %}
                  <img
                    src="{{ custom_image | image_url: width: 800 }}"
                    alt="{{ custom_image.alt | escape }}"
                    class="ai-collections-slider__image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="{{ custom_image.width }}"
                    height="{{ custom_image.height }}"
                  >
                {% elsif collection.image %}
                  <img
                    src="{{ collection.image | image_url: width: 800 }}"
                    alt="{{ collection.image.alt | default: collection.title | escape }}"
                    class="ai-collections-slider__image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="{{ collection.image.width }}"
                    height="{{ collection.image.height }}"
                  >
                {% else %}
                  <div class="ai-collections-slider__image-placeholder-{{ ai_gen_id }}">
                    {{ 'collection-apparel-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <div class="ai-collections-slider__content-{{ ai_gen_id }}">
                {% if custom_title != blank %}
                  <h3 class="ai-collections-slider__title-{{ ai_gen_id }}">{{ custom_title }}</h3>
                {% elsif collection.title %}
                  <h3 class="ai-collections-slider__title-{{ ai_gen_id }}">{{ collection.title }}</h3>
                {% endif %}

                {% if custom_description != blank %}
                  <div class="ai-collections-slider__description-{{ ai_gen_id }}">{{ custom_description }}</div>
                {% elsif collection.description != blank %}
                  <div class="ai-collections-slider__description-{{ ai_gen_id }}">{{ collection.description | strip_html | truncate: 120 }}</div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="ai-collections-slider__nav-{{ ai_gen_id }}">
    <button
      class="ai-collections-slider__button-{{ ai_gen_id }}"
      data-prev
      aria-label="Previous slide"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <div class="ai-collections-slider__dots-{{ ai_gen_id }}" data-dots></div>

    <button
      class="ai-collections-slider__button-{{ ai_gen_id }}"
      data-next
      aria-label="Next slide"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
</collections-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionsSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.track = this.querySelector('[data-track]');
        this.slides = Array.from(this.track.children);
        this.prevButton = this.querySelector('[data-prev]');
        this.nextButton = this.querySelector('[data-next]');
        this.dotsContainer = this.querySelector('[data-dots]');
        this.dots = [];
      }

      connectedCallback() {
        this.slidesPerView = this.getSlidesPerView();
        this.totalSlides = this.slides.length;
        this.maxIndex = Math.max(0, this.totalSlides - this.slidesPerView);

        this.createDots();
        this.updateSlider();
        this.attachEventListeners();

        window.addEventListener('resize', () => {
          this.slidesPerView = this.getSlidesPerView();
          this.maxIndex = Math.max(0, this.totalSlides - this.slidesPerView);
          this.currentIndex = Math.min(this.currentIndex, this.maxIndex);
          this.updateSlider();
        });
      }

      getSlidesPerView() {
        return window.innerWidth <= 749 ? {{ block.settings.slides_per_view_mobile }} : {{ block.settings.slides_per_view }};
      }

      createDots() {
        this.dotsContainer.innerHTML = '';
        this.dots = [];
        const numDots = this.maxIndex + 1;

        for (let i = 0; i < numDots; i++) {
          const dot = document.createElement('button');
          dot.classList.add('ai-collections-slider__dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          dot.addEventListener('click', () => this.goToSlide(i));
          this.dotsContainer.appendChild(dot);
          this.dots.push(dot);
        }
      }

      attachEventListeners() {
        this.prevButton.addEventListener('click', () => this.prev());
        this.nextButton.addEventListener('click', () => this.next());
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateSlider();
        }
      }

      next() {
        if (this.currentIndex < this.maxIndex) {
          this.currentIndex++;
          this.updateSlider();
        }
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateSlider();
      }

      updateSlider() {
        const slideWidth = this.slides[0].offsetWidth;
        const gap = {{ block.settings.slide_gap }};
        const offset = -(this.currentIndex * (slideWidth + gap));
        
        this.track.style.transform = `translateX(${offset}px)`;

        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex === this.maxIndex;

        this.dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('collections-slider-{{ ai_gen_id }}', CollectionsSlider{{ ai_gen_id }});
  })();
</script>

