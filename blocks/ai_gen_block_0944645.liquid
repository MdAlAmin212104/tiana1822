 {% doc %}
  @prompt
    i want to create a marquary section where i add multiple text within icon image.make sure it responsive all device and also control speed or section size.icon is not too big. , all good but items are not showing properly.like first text and icon are too much close with another items.i want to make sure everything proper layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-marquee-container-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-marquee-wrapper-{{ ai_gen_id }} {
    display: flex;
    width: fit-content;
    animation: ai-marquee-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  .ai-marquee-content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.item_spacing }}px;
    white-space: nowrap;
    padding-right: {{ block.settings.item_spacing }}px;
  }

  .ai-marquee-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_text_gap }}px;
    flex-shrink: 0;
  }

  .ai-marquee-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-marquee-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-marquee-icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
  }

  .ai-marquee-icon-placeholder-{{ ai_gen_id }} svg {
    width: 70%;
    height: 70%;
  }

  .ai-marquee-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    line-height: 1.2;
  }

  @keyframes ai-marquee-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  {% if block.settings.pause_on_hover %}
    .ai-marquee-wrapper-{{ ai_gen_id }}:hover {
      animation-play-state: paused;
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    .ai-marquee-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 | round }}px;
      height: {{ block.settings.icon_size | times: 0.8 | round }}px;
    }

    .ai-marquee-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 | round }}px;
    }

    .ai-marquee-content-{{ ai_gen_id }} {
      gap: {{ block.settings.item_spacing | times: 0.7 | round }}px;
      padding-right: {{ block.settings.item_spacing | times: 0.7 | round }}px;
    }

    .ai-marquee-item-{{ ai_gen_id }} {
      gap: {{ block.settings.icon_text_gap | times: 0.8 | round }}px;
    }
  }
{% endstyle %}

<div class="ai-marquee-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-marquee-wrapper-{{ ai_gen_id }}">
    <div class="ai-marquee-content-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign text_key = 'text_' | append: i
          assign icon_key = 'icon_' | append: i
          assign text_value = block.settings[text_key]
          assign icon_value = block.settings[icon_key]
        %}

        {% if text_value != blank %}
          <div class="ai-marquee-item-{{ ai_gen_id }}">
            <div class="ai-marquee-icon-{{ ai_gen_id }}">
              {% if icon_value %}
                <img
                  src="{{ icon_value | image_url: width: 100 }}"
                  alt="{{ text_value | escape }}"
                  loading="lazy"
                  width="100"
                  height="100"
                >
              {% else %}
                <div class="ai-marquee-icon-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <span class="ai-marquee-text-{{ ai_gen_id }}">{{ text_value }}</span>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="ai-marquee-content-{{ ai_gen_id }}" aria-hidden="true">
      {% for i in (1..5) %}
        {% liquid
          assign text_key = 'text_' | append: i
          assign icon_key = 'icon_' | append: i
          assign text_value = block.settings[text_key]
          assign icon_value = block.settings[icon_key]
        %}

        {% if text_value != blank %}
          <div class="ai-marquee-item-{{ ai_gen_id }}">
            <div class="ai-marquee-icon-{{ ai_gen_id }}">
              {% if icon_value %}
                <img
                  src="{{ icon_value | image_url: width: 100 }}"
                  alt="{{ text_value | escape }}"
                  loading="lazy"
                  width="100"
                  height="100"
                >
              {% else %}
                <div class="ai-marquee-icon-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <span class="ai-marquee-text-{{ ai_gen_id }}">{{ text_value }}</span>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

