{% doc %}
  @prompt
    i want to create a section where have a title and title below there is option to add subtitle text.make sure responisve for all device and all of the things editable
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-title-subtitle-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-title-subtitle-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_width }}px;
    margin: 0 auto;
  }

  .ai-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.spacing_between }}px;
    line-height: 1.2;
  }

  .ai-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    font-weight: {{ block.settings.subtitle_weight }};
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-title-subtitle-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px {{ block.settings.section_padding_horizontal_mobile }}px {{ block.settings.section_padding_bottom_mobile }}px;
    }

    .ai-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
      margin: 0 0 {{ block.settings.spacing_between_mobile }}px;
    }

    .ai-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-title-subtitle-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-title-subtitle-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}
    
    {% if block.settings.subtitle != blank %}
      <div class="ai-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
    {% endif %}
  </div>
</div>

