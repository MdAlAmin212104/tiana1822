{% doc %}
  @prompt
    i want to create a product slider section where i upload a collection then it shows those collection products.make sure everything editable and responsive for all device.When it goes to mobile device i want to show one product for one screen and then click arrow then shows other one .also add a heading on the section, all good.i want product title and price should be centered position, everthing perfect.just little change.the gap between title and price need to be reduced, everthing perfect.just little change.the gap between title and price need to be reduced
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-slider-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-product-slider-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-product-slider-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-product-slider-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    font-weight: {{ block.settings.heading_weight }};
  }

  .ai-product-slider-wrapper-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-product-slider-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.product_gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-product-slider-track-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-product-slider-item-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.products_per_row_desktop | minus: 1 }} * {{ block.settings.product_gap }}px)) / {{ block.settings.products_per_row_desktop }});
    min-width: calc((100% - ({{ block.settings.products_per_row_desktop | minus: 1 }} * {{ block.settings.product_gap }}px)) / {{ block.settings.products_per_row_desktop }});
  }

  .ai-product-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
  }

  .ai-product-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-product-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-product-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-product-info-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    text-align: center;
  }

  .ai-product-vendor-{{ ai_gen_id }} {
    font-size: {{ block.settings.vendor_size }}px;
    color: {{ block.settings.vendor_color }};
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 4px;
    font-weight: 500;
    line-height: 1.3;
  }

  .ai-product-title-link-{{ ai_gen_id }} {
    color: inherit;
    text-decoration: none;
  }

  .ai-product-title-link-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    margin-top: auto;
  }

  .ai-product-price-regular-{{ ai_gen_id }} {
    font-weight: 600;
  }

  .ai-product-price-compare-{{ ai_gen_id }} {
    text-decoration: line-through;
    opacity: 0.6;
    margin-left: 8px;
  }

  .ai-slider-nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: {{ block.settings.nav_spacing }}px;
  }

  .ai-slider-button-{{ ai_gen_id }} {
    width: {{ block.settings.nav_button_size }}px;
    height: {{ block.settings.nav_button_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.nav_button_bg }};
    color: {{ block.settings.nav_button_color }};
    border: {{ block.settings.nav_button_border }}px solid {{ block.settings.nav_button_border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-slider-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_bg }};
    color: {{ block.settings.nav_button_hover_color }};
  }

  .ai-slider-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-slider-button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-slider-dots-{{ ai_gen_id }} {
    display: none;
    gap: 8px;
  }

  .ai-slider-dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.3;
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
    padding: 0;
  }

  .ai-slider-dot-{{ ai_gen_id }}.active {
    opacity: 1;
    background-color: {{ block.settings.dot_active_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-product-slider-item-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.products_per_row_tablet | minus: 1 }} * {{ block.settings.product_gap }}px)) / {{ block.settings.products_per_row_tablet }});
      min-width: calc((100% - ({{ block.settings.products_per_row_tablet | minus: 1 }} * {{ block.settings.product_gap }}px)) / {{ block.settings.products_per_row_tablet }});
    }
  }

  @media screen and (max-width: 749px) {
    .ai-product-slider-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-product-slider-item-{{ ai_gen_id }} {
      flex: 0 0 100%;
      min-width: 100%;
    }

    .ai-slider-nav-{{ ai_gen_id }} {
      margin-top: 24px;
    }

    .ai-slider-dots-{{ ai_gen_id }} {
      display: flex;
    }
  }
{% endstyle %}

<product-slider-{{ ai_gen_id }} class="ai-product-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-slider-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <div class="ai-product-slider-header-{{ ai_gen_id }}">
        <h2 class="ai-product-slider-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="ai-product-slider-wrapper-{{ ai_gen_id }}">
      <div class="ai-product-slider-track-{{ ai_gen_id }}" data-slider-track>
        {% if block.settings.collection != blank %}
          {% assign collection = block.settings.collection %}
          {% assign products_to_show = block.settings.products_limit %}
          
          {% for product in collection.products limit: products_to_show %}
            <div class="ai-product-slider-item-{{ ai_gen_id }}">
              <div class="ai-product-card-{{ ai_gen_id }}">
                <div class="ai-product-image-wrapper-{{ ai_gen_id }}">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      class="ai-product-image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="600"
                      height="600"
                    >
                  {% else %}
                    <div class="ai-product-image-placeholder-{{ ai_gen_id }}">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
                <div class="ai-product-info-{{ ai_gen_id }}">
                  {% if block.settings.show_vendor and product.vendor != blank %}
                    <div class="ai-product-vendor-{{ ai_gen_id }}">{{ product.vendor }}</div>
                  {% endif %}
                  <h3 class="ai-product-title-{{ ai_gen_id }}">
                    <a href="{{ product.url }}" class="ai-product-title-link-{{ ai_gen_id }}">
                      {{ product.title }}
                    </a>
                  </h3>
                  {% if block.settings.show_price %}
                    <div class="ai-product-price-{{ ai_gen_id }}">
                      {% if product.compare_at_price > product.price %}
                        <span class="ai-product-price-regular-{{ ai_gen_id }}">{{ product.price | money }}</span>
                        <span class="ai-product-price-compare-{{ ai_gen_id }}">{{ product.compare_at_price | money }}</span>
                      {% else %}
                        <span class="ai-product-price-regular-{{ ai_gen_id }}">{{ product.price | money }}</span>
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}
        {% else %}
          {% for i in (1..6) %}
            <div class="ai-product-slider-item-{{ ai_gen_id }}">
              <div class="ai-product-card-{{ ai_gen_id }}">
                <div class="ai-product-image-wrapper-{{ ai_gen_id }}">
                  <div class="ai-product-image-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                </div>
                <div class="ai-product-info-{{ ai_gen_id }}">
                  <h3 class="ai-product-title-{{ ai_gen_id }}">Product title</h3>
                  <div class="ai-product-price-{{ ai_gen_id }}">
                    <span class="ai-product-price-regular-{{ ai_gen_id }}">$29.99</span>
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}
        {% endif %}
      </div>

      <div class="ai-slider-nav-{{ ai_gen_id }}">
        <button
          class="ai-slider-button-{{ ai_gen_id }} ai-slider-prev-{{ ai_gen_id }}"
          data-slider-prev
          aria-label="Previous slide"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </button>

        <div class="ai-slider-dots-{{ ai_gen_id }}" data-slider-dots></div>

        <button
          class="ai-slider-button-{{ ai_gen_id }} ai-slider-next-{{ ai_gen_id }}"
          data-slider-next
          aria-label="Next slide"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</product-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = this.querySelector('[data-slider-track]');
        this.prevButton = this.querySelector('[data-slider-prev]');
        this.nextButton = this.querySelector('[data-slider-next]');
        this.dotsContainer = this.querySelector('[data-slider-dots]');
        this.items = this.querySelectorAll('.ai-product-slider-item-{{ ai_gen_id }}');
        this.currentIndex = 0;
        this.itemsPerView = this.getItemsPerView();
      }

      connectedCallback() {
        this.setupEventListeners();
        this.createDots();
        this.updateButtons();
        this.updateDots();

        window.addEventListener('resize', () => {
          this.itemsPerView = this.getItemsPerView();
          this.createDots();
          this.updateButtons();
          this.updateDots();
        });
      }

      getItemsPerView() {
        if (window.innerWidth <= 749) {
          return 1;
        } else if (window.innerWidth <= 989) {
          return {{ block.settings.products_per_row_tablet }};
        } else {
          return {{ block.settings.products_per_row_desktop }};
        }
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.prev());
        this.nextButton.addEventListener('click', () => this.next());

        let startX = 0;
        let scrollLeft = 0;

        this.track.addEventListener('touchstart', (e) => {
          startX = e.touches[0].pageX;
          scrollLeft = this.track.scrollLeft;
        });

        this.track.addEventListener('touchmove', (e) => {
          const x = e.touches[0].pageX;
          const walk = (startX - x) * 2;
          this.track.scrollLeft = scrollLeft + walk;
        });

        this.track.addEventListener('touchend', () => {
          this.snapToClosest();
        });

        this.track.addEventListener('scroll', () => {
          this.updateCurrentIndex();
        });
      }

      createDots() {
        if (!this.dotsContainer) return;
        
        this.dotsContainer.innerHTML = '';
        const totalDots = Math.ceil(this.items.length / this.itemsPerView);

        for (let i = 0; i < totalDots; i++) {
          const dot = document.createElement('button');
          dot.className = 'ai-slider-dot-{{ ai_gen_id }}';
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          dot.addEventListener('click', () => this.goToSlide(i));
          this.dotsContainer.appendChild(dot);
        }
      }

      updateDots() {
        if (!this.dotsContainer) return;
        
        const dots = this.dotsContainer.querySelectorAll('.ai-slider-dot-{{ ai_gen_id }}');
        const activeDotIndex = Math.floor(this.currentIndex / this.itemsPerView);
        
        dots.forEach((dot, index) => {
          if (index === activeDotIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      updateCurrentIndex() {
        const itemWidth = this.items[0].offsetWidth;
        const gap = {{ block.settings.product_gap }};
        const scrollPosition = this.track.scrollLeft;
        this.currentIndex = Math.round(scrollPosition / (itemWidth + gap));
        this.updateButtons();
        this.updateDots();
      }

      snapToClosest() {
        const itemWidth = this.items[0].offsetWidth;
        const gap = {{ block.settings.product_gap }};
        const scrollPosition = this.track.scrollLeft;
        const closestIndex = Math.round(scrollPosition / (itemWidth + gap));
        this.goToSlide(closestIndex);
      }

      goToSlide(index) {
        const itemWidth = this.items[0].offsetWidth;
        const gap = {{ block.settings.product_gap }};
        const maxIndex = this.items.length - this.itemsPerView;
        
        this.currentIndex = Math.max(0, Math.min(index, maxIndex));
        this.track.scrollTo({
          left: this.currentIndex * (itemWidth + gap),
          behavior: 'smooth'
        });
        
        this.updateButtons();
        this.updateDots();
      }

      prev() {
        this.goToSlide(this.currentIndex - this.itemsPerView);
      }

      next() {
        this.goToSlide(this.currentIndex + this.itemsPerView);
      }

      updateButtons() {
        const maxIndex = this.items.length - this.itemsPerView;
        
        if (this.currentIndex <= 0) {
          this.prevButton.disabled = true;
        } else {
          this.prevButton.disabled = false;
        }

        if (this.currentIndex >= maxIndex) {
          this.nextButton.disabled = true;
        } else {
          this.nextButton.disabled = false;
        }
      }
    }

    customElements.define('product-slider-{{ ai_gen_id }}', ProductSlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
