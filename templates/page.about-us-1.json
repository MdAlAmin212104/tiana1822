    "2d11636f-e0da-4a86-b3b5-c1eda5735347": {
      "type": "rich-text",
      "blocks": {
        "7407acef-3e90-41f5-9ecf-356bd562c30b": {
          "type": "heading",
          "settings": {
            "title": "Keeping It Pure",
            "size_text": "h2"
          }
        },
        "8a950665-fd5a-43a3-bf89-8ba1c9967e92": {
          "type": "paragraph",
          "settings": {
            "subtext": "“Keeping It Pure” means honoring your body with products that nourish, protect, and restore naturally. It is the heart of Fleuriation’s pledge. We believe purity begins with integrity; from the ingredients we choose to the way each product is crafted. Every formulation is made with high-quality, non-toxic, and naturally derived ingredients that reflect the simplicity and medicinal wonders of herbs. We avoid harmful chemicals, synthetic fragrances, and unnecessary fillers to ensure that what touches your skin is non-toxic, effective, and true to nature. Our process honors transparency and sustainability, allowing each product to embody clean beauty as it was intended: pure, honest, and purposeful."
          }
        }
      },
