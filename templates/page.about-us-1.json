    "b2ef3f00-5f4f-4e93-8187-3970a28a8f9e": {
      "type": "parallax-banner",
      "blocks": {
        "template--19549173514560__b2ef3f00-5f4f-4e93-8187-3970a28a8f9e-heading-1": {
          "type": "heading",
          "settings": {
            "title": "High-Quality Ingredients",
            "size_text": "h1"
          }
        },
        "94c7371c-d71f-4781-892e-d23c731daa77": {
          "type": "paragraph",
          "settings": {
            "subtext": "We are devoted to crafting products with the highest quality of organic and all-natural ingredients. Every botanical extract, cold-pressed oil, and herbal infusion is thoughtfully selected for its proven nourishment, potency, and integrity. Our plant-based oils are rich in essential fatty acids and antioxidants that help strengthen the skin’s barrier, lock in moisture, and support a radiant complexion. Herbal extracts are chosen for their soothing and anti-inflammatory properties to calm irritation and promote restoration, while natural humectants help maintain optimal hydration. Every ingredient serves a clear purpose, working in harmony with your skin’s natural functions rather than against them. Our ingredients are sourced from ethical growers and trusted suppliers who share our commitment to sustainability and non-toxic living. Free from synthetic fragrances, parabens, and harsh/synthetic chemicals."
          }
        }
      },
