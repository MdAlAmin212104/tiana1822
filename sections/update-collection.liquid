<!-- sections/collection-promo-grid.liquid -->
{%- liquid
  assign collection = collections[section.settings.collection]
  assign limit = section.settings.limit
  assign columns = section.settings.slides_to_show
  assign enable_slider = section.settings.enable_slider
  assign arrows = section.settings.arrows
  assign dots = section.settings.dots
  assign promo_pos = section.settings.promo_position
  assign overlay_bg = section.settings.overlay_color
  assign overlay_opacity = section.settings.overlay_opacity
  assign promo_text_color = section.settings.promo_text_color
-%}

{%- style -%}

.productlist-slider, .productlist-swiper .row, .productlist-wrapper .row, .index-products .row, .product-image__product .row, .main-collection-template .row {
    display: block!important;
}

  .customstyle{{ section.id }} {
    --forest: #2F4A3C;
    --cream: #F7F4EC;
    --gold: #C79A3C;
    --charcoal: #2B2B28;
    --overlay-color: {{ overlay_bg }};
    --overlay-opacity: {{ overlay_opacity }};
  }

  /* ===== Section Wrap ===== */
  .customstyle{{ section.id }} .cpg-section{
    padding: 36px 0 50px;
  }

  .customstyle{{ section.id }} .cpg-wrap{
    width: 100%;
    margin: 0 auto;
    padding: 0 15px;
  }
  .customstyle{{ section.id }} .cpg-wrap--boxed {
    max-width: 1320px;
  }
  .customstyle{{ section.id }} .cpg-wrap--fluid {
    max-width: 100%;
    padding-left: 30px;
    padding-right: 30px;
  }
  .customstyle{{ section.id }} .cpg-wrap--full {
    max-width: 100%;
    padding-left: 0;
    padding-right: 0;
  }

  /* ===== Main two-column layout ===== */
  .customstyle{{ section.id }} .collection-promo-grid__container{
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .customstyle{{ section.id }} .collection-promo-grid__promo-col{ width: 100%; }
  .customstyle{{ section.id }} .collection-promo-grid__content-col{
    width: 100%;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  @media (min-width: 992px){
    .customstyle{{ section.id }} .collection-promo-grid__container{
      display: grid;
      grid-template-columns: 28% 72%;
      column-gap: 10px;
    }
    .customstyle{{ section.id }} .collection-promo-grid__container.promo-pos-right{
      grid-template-columns: 72% 28%;
    }
    .customstyle{{ section.id }} .collection-promo-grid__promo-col{ grid-column: 1; }
    .customstyle{{ section.id }} .collection-promo-grid__container.promo-pos-right .collection-promo-grid__promo-col{ grid-column: 2; }
    .customstyle{{ section.id }} .collection-promo-grid__content-col{ grid-column: 2; }
    .customstyle{{ section.id }} .collection-promo-grid__container.promo-pos-right .collection-promo-grid__content-col{ grid-column: 1; }
  }

  /* ===== Promo Block ===== */
  .customstyle{{ section.id }} .promo-block{
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    height: 100%;
    min-height: 480px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
  }

  @media (max-width: 991px){
    .customstyle{{ section.id }} .promo-block{ min-height: 350px; }
  }

  .customstyle{{ section.id }} .promo-block__image-wrapper{
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(135deg, var(--forest), #1c3229);
  }

  .customstyle{{ section.id }} .promo-block__image-wrapper img{
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .customstyle{{ section.id }} .promo-block__overlay{
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background-color: var(--overlay-color);
    opacity: var(--overlay-opacity);
  }

  .customstyle{{ section.id }} .promo-block__content{
    position: relative;
    z-index: 2;
    padding: 30px;
    color: var(--text-color, var(--cream));
  }

  .customstyle{{ section.id }} .promo-block__text{
    font-size: 1.1rem;
    line-height: 1.5;
    margin-bottom: 20px;
    font-weight: 500;
  }

  .customstyle{{ section.id }} .promo-block__btn-wrapper{
    display: flex;
    justify-content: center;
  }

  /* ===== Buttons ===== */
  .customstyle{{ section.id }} .btn{
    display: inline-block;
    padding: 13px 28px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    border-radius: 2px;
    transition: background-color .3s ease, color .3s ease, border-color .3s ease;
    border: 1px solid transparent;
  }
  
  
  .customstyle{{ section.id }} .btn-theme.btn-white:hover{ background: var(--cream); }
  .customstyle{{ section.id }} .btn-underline{
    background: transparent;
    color: var(--charcoal);
    padding: 8px 0;
    border-bottom: 1px solid var(--charcoal);
    border-radius: 0;
  }
  .customstyle{{ section.id }} .btn-underline:hover{ opacity: .7; }
  .customstyle{{ section.id }} .btn-underline.btn-underline-white{
    color: #fff;
    border-bottom-color: #fff;
  }
  .customstyle{{ section.id }} .btn-outline{
    background: transparent;
    color: var(--charcoal);
    border-color: var(--charcoal);
  }
  .customstyle{{ section.id }} .btn-outline:hover{ background: var(--charcoal); color: #fff; }
  .customstyle{{ section.id }} .btn-outline.btn-outline-white{
    color: #fff;
    border-color: #fff;
  }
  .customstyle{{ section.id }} .btn-outline.btn-outline-white:hover{ background: #fff; color: var(--charcoal); }

  /* ===== Heading Row ===== */
  .customstyle{{ section.id }} .promo-grid__heading-holder{
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 30px;
    flex-wrap: wrap;
    gap: 15px;
    border-bottom: 1px solid #e8e8e8;
    padding-bottom: 15px;
  }
  .customstyle{{ section.id }} .promo-grid__heading-text{ flex: 1 1 auto; margin-left: 20px; }
  .customstyle{{ section.id }} .promo-grid__heading{
    margin: 0 0 8px;
    font-size: 2.25rem;
    font-weight: 600;
    color: var(--forest);
  }
  .customstyle{{ section.id }} .promo-grid__description{
    font-size: 0.95rem;
    color: #666;
    margin: 0;
  }
  .customstyle{{ section.id }} .promo-grid__heading-actions{ flex: 0 0 auto; }

  /* ===== Static Product Grid ===== */
  .customstyle{{ section.id }} .cpg-product-grid{
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  @media (min-width: 768px){
    .customstyle{{ section.id }} .cpg-product-grid{
      grid-template-columns: repeat(var(--cpg-cols, 3), 1fr);
    }
  }
  .customstyle{{ section.id }} .productlist-item{ display: flex; }

  /* ===== Vanilla Product Slider ===== */
  .customstyle{{ section.id }} .productlist-slider{
    position: relative;
  }
  .customstyle{{ section.id }} .productlist-slider__track{
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
  }
  .customstyle{{ section.id }} .productlist-slider__track::-webkit-scrollbar{ display: none; }
  .customstyle{{ section.id }} .productlist-slider__track{ scrollbar-width: none; }

  .customstyle{{ section.id }} .productlist-slider .productlist-item{
    scroll-snap-align: start;
    flex: 0 0 calc((100% - (var(--cpg-slider-cols, 3) - 1) * 1px) / var(--cpg-slider-cols, 3));
  }
  @media (max-width: 767px){
    .customstyle{{ section.id }} .productlist-slider .productlist-item{
      flex: 0 0 calc(100% / 2 - 10px);
    }
  }

  .customstyle{{ section.id }} .productlist-slider__arrow{
    position: absolute;
    top: 40%;
    transform: translateY(-50%);
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1px solid #ddd;
    background: #fff;
    color: var(--charcoal);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    box-shadow: 0 2px 6px rgba(0,0,0,0.08);
    transition: background-color .2s ease;
  }
  .customstyle{{ section.id }} .productlist-slider__arrow:hover{ background: var(--cream); }
  .customstyle{{ section.id }} .productlist-slider__arrow--prev{ left: -19px; }
  .customstyle{{ section.id }} .productlist-slider__arrow--next{ right: -19px; }
  .customstyle{{ section.id }} .productlist-slider__arrow svg{ width: 16px; height: 16px; fill: none; }

  .customstyle{{ section.id }} .productlist-slider__dots{
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 16px;
  }
  .customstyle{{ section.id }} .productlist-slider__dots button{
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: #ddd;
    padding: 0;
    cursor: pointer;
  }
  .customstyle{{ section.id }} .productlist-slider__dots button.is-active{ background: var(--forest); }


{%- endstyle -%}

<div class="customstyle{{ section.id }}" data-aos="{{ section.settings.animation }}" id="CollectionPromoGrid-{{ section.id }}">
  {%- render 'style-section' -%}

  {%- liquid
    case section.settings.setwidth
      when 'container'
        assign wrap_class = 'cpg-wrap--boxed'
      when 'container-fluid'
        assign wrap_class = 'cpg-wrap--fluid'
      else
        assign wrap_class = 'cpg-wrap--full'
    endcase
  -%}

  <section class="cpg-section">
    <div class="cpg-wrap {{ wrap_class }}">
      <div class="collection-promo-grid__container promo-pos-{{ promo_pos }}">

        <!-- Promo Column -->
        <div class="collection-promo-grid__promo-col">
          <div class="promo-block">
            <div class="promo-block__image-wrapper">
              {%- if section.settings.promo_image != blank -%}
                {% assign img_url = section.settings.promo_image | image_url: width: 1 | replace: 'width=1', 'width={width}' %}
                <img class="lazyload scale-in"
                     src="{{ section.settings.promo_image | image_url: width: 720 }}"
                     data-src="{{ img_url }}"
                     data-widths="[180, 360, 540, 720, 900, 1080]"
                     data-aspectratio="{{ section.settings.promo_image.aspect_ratio }}"
                     data-sizes="auto"
                     alt="{{ section.settings.promo_image.alt | escape }}"
                     loading="lazy">
              {%- else -%}
                <img src="https://images.unsplash.com/photo-1556228720-195a672e8a03?w=720&q=80" alt="Promo">
              {%- endif -%}
            </div>
            <div class="promo-block__overlay"></div>
            <div class="promo-block__content" style="--text-color: {{ promo_text_color }};">
              {%- if section.settings.promo_text != blank -%}
                <div class="promo-block__text">
                  {{ section.settings.promo_text }}
                </div>
              {%- endif -%}
              {%- if section.settings.promo_btn_label != blank and section.settings.promo_btn_link != blank -%}
                <div class="promo-block__btn-wrapper">
                  <a href="{{ section.settings.promo_btn_link }}" class="btn {{ section.settings.style_btn_promo }}">
                    {{ section.settings.promo_btn_label | escape }}
                  </a>
                </div>
              {%- endif -%}
            </div>
          </div>
        </div>

        <!-- Content Column -->
        <div class="collection-promo-grid__content-col">
          <div class="promo-grid__heading-holder">
            <div class="promo-grid__heading-text">
              {%- if section.settings.title != blank -%}
                <h2 class="promo-grid__heading">{{ section.settings.title | escape }}</h2>
              {%- endif -%}
              {%- if section.settings.description != blank -%}
                <div class="promo-grid__description">{{ section.settings.description }}</div>
              {%- endif -%}
            </div>
            {%- if section.settings.view_all_text != blank and section.settings.view_all_link != blank -%}
              <div class="promo-grid__heading-actions">
                <a href="{{ section.settings.view_all_link }}" class="btn {{ section.settings.style_btn_all }}">
                  {{ section.settings.view_all_text | escape }}
                </a>
              </div>
            {%- endif -%}
          </div>

          <div class="grid-outer">
            {%- if enable_slider -%}
              <div class="productlist-slider" style="--cpg-slider-cols: {{ columns }};">
                <button class="productlist-slider__arrow productlist-slider__arrow--prev" aria-label="Previous">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
                </button>
                <div class="productlist-slider__track">
                  {%- if collection != blank and collection.products.size > 0 -%}
                    {%- for product in collection.products limit: limit -%}
                      <div class="productlist-item">
                        {%- render 'product-card', product: product -%}
                      </div>
                    {%- endfor -%}
                  {%- else -%}
                    {%- for i in (1..limit) -%}
                      <div class="productlist-item">
                        {%- render 'product-grid-blank' -%}
                      </div>
                    {%- endfor -%}
                  {%- endif -%}
                </div>
                <button class="productlist-slider__arrow productlist-slider__arrow--next" aria-label="Next">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
                </button>
              </div>
              <div class="productlist-slider__dots"></div>
            {%- else -%}
              <div class="cpg-product-grid" style="--cpg-cols: {{ columns }};">
                {%- if collection != blank and collection.products.size > 0 -%}
                  {%- for product in collection.products limit: limit -%}
                    <div class="productlist-item">
                      {%- render 'product-card', product: product -%}
                    </div>
                  {%- endfor -%}
                {%- else -%}
                  {%- for i in (1..limit) -%}
                    <div class="productlist-item">
                      {%- render 'product-grid-blank' -%}
                    </div>
                  {%- endfor -%}
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>

      </div>
    </div>
  </section>
</div>

<script>
(function() {
  function initPromoSlider(container) {
    if (!container || container.dataset.promoSliderInitialized) return;
    container.dataset.promoSliderInitialized = "true";

    var track = container.querySelector('.productlist-slider__track');
    var dotsWrap = container.querySelector('.productlist-slider__dots');
    var slider = container.querySelector('.productlist-slider');
    if (!slider || !track) return;
    var prevBtn = slider.querySelector('.productlist-slider__arrow--prev');
    var nextBtn = slider.querySelector('.productlist-slider__arrow--next');

    var slidesToShow = parseInt(slider.style.getPropertyValue('--cpg-slider-cols')) || 3;
    var arrowsEnabled = {{ arrows | default: true }};
    var dotsEnabled = {{ dots | default: false }};
    
    var items = track.querySelectorAll('.productlist-item');
    var totalItems = items.length;

    function slideWidth() {
      var item = track.querySelector('.productlist-item');
      if (!item) return 0;
      var gap = 20; 
      return item.getBoundingClientRect().width + gap;
    }

    function scrollByCards(dir) {
      track.scrollBy({ left: dir * slideWidth(), behavior: 'smooth' });
    }

    if (arrowsEnabled && prevBtn && nextBtn) {
      prevBtn.addEventListener('click', function() { scrollByCards(-1); });
      nextBtn.addEventListener('click', function() { scrollByCards(1); });
      
      function toggleArrows() {
        if (track.scrollWidth <= track.clientWidth) {
          prevBtn.style.display = 'none';
          nextBtn.style.display = 'none';
        } else {
          prevBtn.style.display = 'flex';
          nextBtn.style.display = 'flex';
        }
      }
      toggleArrows();
      window.addEventListener('resize', toggleArrows);
    } else {
      if (prevBtn) prevBtn.style.display = 'none';
      if (nextBtn) nextBtn.style.display = 'none';
    }

    function buildDots() {
      if (!dotsEnabled || !dotsWrap) {
        if (dotsWrap) dotsWrap.style.display = 'none';
        return;
      }
      var pageCount = Math.max(1, Math.ceil(totalItems / slidesToShow));
      dotsWrap.innerHTML = '';
      if (pageCount <= 1) {
        dotsWrap.style.display = 'none';
        return;
      } else {
        dotsWrap.style.display = 'flex';
      }
      for (var i = 0; i < pageCount; i++) {
        var dot = document.createElement('button');
        if (i === 0) dot.classList.add('is-active');
        dot.setAttribute('aria-label', 'Go to slide page ' + (i + 1));
        dot.addEventListener('click', (function(idx) {
          return function() {
            track.scrollTo({ left: idx * slidesToShow * slideWidth(), behavior: 'smooth' });
          };
        })(i));
        dotsWrap.appendChild(dot);
      }
    }
    
    buildDots();

    track.addEventListener('scroll', function() {
      if (!dotsEnabled || !dotsWrap) return;
      var page = Math.round(track.scrollLeft / (slidesToShow * slideWidth()));
      var allDots = dotsWrap.querySelectorAll('button');
      allDots.forEach(function(d, i) {
        d.classList.toggle('is-active', i === page);
      });
    });

    window.addEventListener('resize', buildDots);
  }

  document.addEventListener('DOMContentLoaded', function() {
    var container = document.getElementById('CollectionPromoGrid-{{ section.id }}');
    if (container) initPromoSlider(container);
  });
  
  document.addEventListener('shopify:section:load', function(event) {
    if (event.detail.sectionId === '{{ section.id }}') {
      var container = document.getElementById('CollectionPromoGrid-{{ section.id }}');
      if (container) initPromoSlider(container);
    }
  });

  var container = document.getElementById('CollectionPromoGrid-{{ section.id }}');
  if (container) initPromoSlider(container);
})();
</script>

{% schema %}
