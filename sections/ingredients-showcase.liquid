    {
      "type": "image_picker",
      "id": "default_ing_1_image",
      "label": "Ingredient 1 Image"
    },
    {
      "type": "text",
      "id": "default_ing_2_title",
      "label": "Ingredient 2 Name",
      "default": "Aloe Vera Juice"
    },
    {
      "type": "richtext",
      "id": "default_ing_2_desc",
      "label": "Ingredient 2 Description",
      "default": "<p>This succulent is a natural source of antioxidants and stimulates the production of hyaluronic acid in the skin to decrease inflammation and rebuild hydration. Its healing properties also help to protect and repair skin from environmental stressors.</p>"
    },
    {
      "type": "image_picker",
      "id": "default_ing_2_image",
      "label": "Ingredient 2 Image"
    },
    {
      "type": "text",
      "id": "default_ing_3_title",
      "label": "Ingredient 3 Name",
      "default": "Shea Butter"
    },
    {
      "type": "richtext",
      "id": "default_ing_3_desc",
      "label": "Ingredient 3 Description",
      "default": "<p>High concentrations of fatty acids, anti-inflammatory compounds and vitamins make shea butter the best healthy fat for softening skin and provide a much-needed boost of nourishment.</p>"
    },
    {
      "type": "image_picker",
      "id": "default_ing_3_image",
      "label": "Ingredient 3 Image"
    },
    {
      "type": "text",
      "id": "default_ing_4_title",
      "label": "Ingredient 4 Name",
      "default": "Essential Oils of Orange and Peppermint"
    },
    {
      "type": "richtext",
      "id": "default_ing_4_desc",
      "label": "Ingredient 4 Description",
      "default": "<p>A fresh, uplifting synergistic blend of essential oils that purifies, balances and brightens the skin with minerals, vitamins, antioxidants and antibacterial benefits.</p>"
    },
    {
      "type": "image_picker",
      "id": "default_ing_4_image",
      "label": "Ingredient 4 Image"
    },
